config {
  type: "view",
  name: "CITA_Edge_Golden"
}

SELECT
  e.id_evento AS source_id,
  c.confrontado_com_id AS target_id,
  CASE
    WHEN c.status_entrega = 'Entregue' THEN 'VALID'
    ELSE 'PENDING'
  END AS validation_status,
  CURRENT_TIMESTAMP() AS updated_at
FROM
  ${ref("eventos_unstructured")} e
JOIN
  ${ref("citacoes_raw")} c
ON
  e.proc_ref = c.num_proc
WHERE
  UPPER(e.txt_movimento) LIKE '%CITACAO%'
